# --- Amazon Associates ---
# Your Amazon Associates tag (the part after "tag=" in your affiliate links).
# Find it in Associates Central → Account → Account Settings.
NEXT_PUBLIC_AMAZON_TAG=poshnestfinds-20

# --- Newsletter ---
# POST endpoint that accepts a JSON body { "email": "..." }.
# Examples:
#   Mailchimp embed form URL (replace /post with /post-json?u=...&id=...)
#   ConvertKit form endpoint
#   Buttondown form endpoint
#   A Vercel serverless function URL
# Leave blank to disable submissions (form will show a "coming soon" message).
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=

# --- Analytics ---
# Either "plausible" or "ga4". Leave blank to disable.
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_ANALYTICS_ID=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (Neon Postgres) ---
# Sign up free at https://neon.tech → create a project → copy the connection
# string. The `?sslmode=require` suffix is required.
DATABASE_URL=postgresql://neondb_owner:npg_HnysWbk9tPN1@ep-cold-king-adtl61yr.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Admin auth ---
# Username the admin logs in with. Single user only.
ADMIN_USERNAME=admin

# Bcrypt hash of the admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_PASSWORD_HASH=

# Random 32+ char string used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
